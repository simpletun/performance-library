{
  "name": "cluster-load-runner",
  "version": "1.1.0",
  "description": "A library for performance testing utilities",
  "publishConfig": {
    "registry": "https://registry.npmjs.org/"
  },
  "type": "module",
  "main": "src/index.js",
  "types": "./index.d.ts",
  "exports": {
    ".": "./src/index.js",
    "./master": "./src/master.js",
    "./worker": "./src/worker.js"
  },
  "scripts": {
    "clean": "rimraf ./reports ./docs ./coverage",
    "coverage": "c8 --reporter=html --reporter=text npm test",
    "jsdoc": "jsdoc -r -p -c .jsdoc.json -d docs",
    "lint": "eslint src -f html -o ./reports/eslint.html",
    "prepublishOnly": "npm test",
    "test": "mocha"
  },
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/simpletun/performance-library.git"
  },
  "author": "Adam Olsen <aolsen1@gmail.com>",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/exporter-metrics-otlp-http": "^0.218.0",
    "@opentelemetry/resources": "^2.7.1",
    "@opentelemetry/sdk-metrics": "^2.7.1",
    "csv-stringify": "^6.7.0",
    "follow-redirects": "^1.15.0",
    "json-stable-stringify": "^1.0.1",
    "jsonpath-plus": "^10.3.0",
    "mkdirp": "^3.0.1",
    "mysql": "^2.18.1",
    "winston": "^3.14.0"
  },
  "devDependencies": {
    "c8": "^10.0.0",
    "cross-env": "^7.0.3",
    "docdash": "^2.0.0",
    "eslint": "^9.11.0",
    "esmock": "^2.7.4",
    "jsdoc": "^4.0.3",
    "mocha": "^10.7.0",
    "rimraf": "^6.0.0"
  },
  "overrides": {
    "serialize-javascript": ">=7.0.5"
  },
  "peerDependencies": {
    "@opentelemetry/auto-instrumentations-node": "^0.50.0",
    "@splunk/otel": "^2.12.0"
  },
  "peerDependenciesMeta": {
    "@opentelemetry/auto-instrumentations-node": {
      "optional": true
    },
    "@splunk/otel": {
      "optional": true
    }
  }
}
