# -----------------------------------------------------------------------------
# Sample Environment Variables Configuration
# Copy this file to .env and replace the placeholder values with your actual data.
# Ensure .env is added to your .gitignore file!
# -----------------------------------------------------------------------------

# --- InfluxDB Configuration ---
# Used by the InfluxDbStream output plugin to record test metrics
INFLUX_URL=http://localhost:8086
INFLUX_TOKEN=your_super_secret_influx_api_token_here
INFLUX_ORG=your_organization_name
INFLUX_BUCKET=performance_metrics_bucket